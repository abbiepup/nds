{
    "abi": "eabi",
    "arch": "arm",
    "cpu": "arm7tdmi",
    "llvm-target": "armv4t-none-eabi",
    "llvm-floatabi": "soft",
    "features": "+soft-float,+strict-align",
    "has-thumb-interworking": true,
    "target-pointer-width": "32",
    "data-layout": "e-m:e-p:32:32-Fi8-i64:64-v128:64:128-a:0:32-n32-S64",
    "asm-args": [
        "-mthumb-interwork",
        "-march=armv4t",
        "-mlittle-endian"
    ]
}